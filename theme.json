{
	"$schema": "https://schemas.wp.org/wp/6.5/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1600px",
			"allowEditing": true,
			"allowCustomContentAndWideSize": true
		},
		"color": {
			"custom": true,
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"customGradient": true,
			"customDuotone": true,
			"background": true,
			"text": true,
			"link": true,
			"heading": true,
			"button": true,
			"caption": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#1a6ef5",
					"name": "Primary"
				},
				{
					"slug": "primary-dark",
					"color": "#0f4fc2",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#f5a623",
					"name": "Accent"
				},
				{
					"slug": "accent-dark",
					"color": "#d48c0e",
					"name": "Accent Dark"
				},
				{
					"slug": "foreground",
					"color": "#1a1a2e",
					"name": "Foreground"
				},
				{
					"slug": "foreground-light",
					"color": "#4a4a68",
					"name": "Foreground Light"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "background-alt",
					"color": "#f4f6fa",
					"name": "Background Alt"
				},
				{
					"slug": "surface",
					"color": "#e8ecf4",
					"name": "Surface"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			],
			"gradients": [
				{
					"slug": "primary-to-accent",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--accent) 100%)",
					"name": "Primary to Accent"
				},
				{
					"slug": "primary-dark-overlay",
					"gradient": "linear-gradient(180deg, rgba(26,110,245,0.9) 0%, rgba(15,79,194,0.95) 100%)",
					"name": "Primary Dark Overlay"
				}
			],
			"duotone": [
				{
					"slug": "primary-white",
					"colors": ["#1a6ef5", "#ffffff"],
					"name": "Primary and White"
				},
				{
					"slug": "foreground-background",
					"colors": ["#1a1a2e", "#f4f6fa"],
					"name": "Foreground and Background"
				}
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": true,
			"dropCap": true,
			"lineHeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true,
			"writingMode": true,
			"fontStyle": true,
			"fontWeight": true,
			"fontFamilies": [
				{
					"slug": "heading",
					"name": "Playfair Display",
					"fontFamily": "'Playfair Display', serif",
					"fontFace": [
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-regular.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-500.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-600.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-700.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-800.woff2"]
						},
						{
							"fontFamily": "Playfair Display",
							"fontWeight": "900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/playfair-display-v40-latin-900.woff2"]
						}
					]
				},
				{
					"slug": "body",
					"name": "Inter",
					"fontFamily": "'Inter', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "300",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-v20-latin-300.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-v20-latin-regular.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-v20-latin-500.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-v20-latin-600.woff2"]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/inter-v20-latin-700.woff2"]
						}
					]
				},
				{
					"slug": "monospace",
					"name": "System Monospace",
					"fontFamily": "ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "sm",
					"size": "clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem)",
					"name": "Small",
					"fluid": {
						"min": "0.75rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "base",
					"size": "clamp(0.875rem, 0.8rem + 0.375vw, 1rem)",
					"name": "Base",
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					}
				},
				{
					"slug": "md",
					"size": "clamp(1rem, 0.9rem + 0.5vw, 1.25rem)",
					"name": "Medium",
					"fluid": {
						"min": "1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "lg",
					"size": "clamp(1.25rem, 1.1rem + 0.75vw, 1.75rem)",
					"name": "Large",
					"fluid": {
						"min": "1.25rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xl",
					"size": "clamp(1.5rem, 1.2rem + 1.5vw, 2.5rem)",
					"name": "Extra Large",
					"fluid": {
						"min": "1.5rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "2-xl",
					"size": "clamp(2rem, 1.5rem + 2.5vw, 3.5rem)",
					"name": "2X Large",
					"fluid": {
						"min": "2rem",
						"max": "3.5rem"
					}
				},
				{
					"slug": "hero",
					"size": "clamp(2.5rem, 1.75rem + 3.75vw, 5rem)",
					"name": "Hero",
					"fluid": {
						"min": "2.5rem",
						"max": "5rem"
					}
				}
			]
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"customSpacingSize": true,
			"defaultSpacingSizes": false,
			"spacingScale": {
				"operator": "*",
				"increment": 2,
				"steps": 7,
				"mediumStep": 1,
				"unit": "rem"
			},
			"spacingSizes": [
				{
					"slug": "xs",
					"size": "4px",
					"name": "Extra Small"
				},
				{
					"slug": "sm",
					"size": "8px",
					"name": "Small"
				},
				{
					"slug": "md",
					"size": "16px",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "32px",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "64px",
					"name": "Extra Large"
				},
				{
					"slug": "2-xl",
					"size": "128px",
					"name": "2X Large"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true,
			"aspectRatio": true
		},
		"position": {
			"sticky": true
		},
		"shadow": {
			"presets": [
				{
					"slug": "sm",
					"name": "Small",
					"shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
				},
				{
					"slug": "md",
					"name": "Medium",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
				},
				{
					"slug": "lg",
					"name": "Large",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
				},
				{
					"slug": "xl",
					"name": "Extra Large",
					"shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--md)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--md)"
			},
			"blockGap": "var(--wp--preset--spacing--lg)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--hero)",
					"fontWeight": "800",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2-xl)",
					"fontWeight": "700",
					"lineHeight": "1.15"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "600",
					"lineHeight": "1.5",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "600",
					"lineHeight": "1"
				},
				"border": {
					"radius": "6px",
					"width": "0"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--sm)",
						"right": "var(--wp--preset--spacing--lg)",
						"bottom": "var(--wp--preset--spacing--sm)",
						"left": "var(--wp--preset--spacing--lg)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"caption": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"text": "var(--wp--preset--color--foreground-light)"
				}
			},
			"cite": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontStyle": "italic"
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"background": "var(--wp--preset--color--background-alt)",
					"text": "var(--wp--preset--color--foreground)"
				},
				"border": {
					"radius": "6px",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--surface)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--md)",
						"right": "var(--wp--preset--spacing--md)",
						"bottom": "var(--wp--preset--spacing--md)",
						"left": "var(--wp--preset--spacing--md)"
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/pullquote": {
				"border": {
					"width": "4px 0 0 0",
					"style": "solid",
					"color": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontStyle": "italic"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--surface)"
				}
			},
			"core/image": {
				"border": {
					"radius": "6px"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"title": "Page (No Title)",
			"postTypes": ["page"]
		}
	],
	"patterns": [
		"ekwa-hero",
		"ekwa-services",
		"ekwa-cta"
	]
}
