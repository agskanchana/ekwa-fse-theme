{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/container",
	"version": "1.0.0",
	"title": "Ekwa Container",
	"category": "design",
	"icon": "align-center",
	"description": "A centered container with configurable max-width.",
	"textdomain": "ekwa",
	"keywords": [ "container", "wrapper", "constrained", "center" ],
	"supports": {
		"html": false,
		"anchor": true,
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		}
	},
	"attributes": {
		"maxWidth": { "type": "string", "default": "1280px" }
	},
	"editorScript": "ekwa-container-editor"
}
