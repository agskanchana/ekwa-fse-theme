{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/section",
	"version": "1.0.0",
	"title": "Ekwa Section",
	"category": "design",
	"icon": "align-wide",
	"description": "A semantic section wrapper with optional background image, overlay, and inner container.",
	"textdomain": "ekwa",
	"keywords": [ "section", "wrapper", "layout", "cover", "hero" ],
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		},
		"shadow": true,
		"dimensions": {
			"minHeight": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"tagName":        { "type": "string",  "default": "section" },
		"containerWidth": { "type": "string",  "default": "" },
		"bgImageUrl":     { "type": "string",  "default": "" },
		"bgImageId":      { "type": "number",  "default": 0 },
		"bgSize":         { "type": "string",  "default": "cover" },
		"bgPosition":     { "type": "string",  "default": "50% 50%" },
		"bgFixed":        { "type": "boolean", "default": false },
		"overlayColor":   { "type": "string",  "default": "" },
		"overlayOpacity": { "type": "number",  "default": 50 }
	},
	"editorScript": "ekwa-section-editor"
}
