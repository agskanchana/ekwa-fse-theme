{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/policy-pages",
	"version": "1.0.0",
	"title": "Policy Pages",
	"category": "common",
	"icon": "shield",
