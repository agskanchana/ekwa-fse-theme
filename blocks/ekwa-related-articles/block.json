{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/related-articles",
	"version": "1.1.0",
	"title": "Ekwa Related Articles",
	"category": "common",
	"icon": "grid-view",
	"description": "On WP pages, lists posts whose category slug matches the page slug. Heading is pluralised by post count. Choose carousel or grid layout.",
	"textdomain": "ekwa",
	"keywords": [ "related", "articles", "posts", "carousel", "page" ],
	"supports": { "html": false },
	"attributes": {
		"useCarousel":           { "type": "boolean", "default": true },
		"count":                 { "type": "number",  "default": 6 },
		"desktopItems":          { "type": "number",  "default": 3 },
		"tabletItems":           { "type": "number",  "default": 2 },
		"mobileItems":           { "type": "number",  "default": 1 },
		"showArrows":            { "type": "boolean", "default": true },
		"showDots":              { "type": "boolean", "default": true },
		"headingLevel":          { "type": "string",  "default": "h2" },
		"singularLabel":         { "type": "string",  "default": "Related article" },
		"pluralLabel":           { "type": "string",  "default": "Related articles" },
		"featuredSingularLabel": { "type": "string",  "default": "Featured article" },
		"featuredPluralLabel":   { "type": "string",  "default": "Featured articles" },
		"featuredCategorySlug":  { "type": "string",  "default": "featured-articles" },
		"hideHeading":           { "type": "boolean", "default": false }
	},
	"editorScript": "ekwa-related-articles-editor"
}
