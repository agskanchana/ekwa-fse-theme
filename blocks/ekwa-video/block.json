{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/video",
	"version": "1.0.0",
	"title": "Ekwa Video",
	"category": "common",
	"icon": "video-alt3",
	"description": "Clean video element — no figure wrapper, no wp-block-video class.",
	"textdomain": "ekwa",
	"keywords": [ "video", "mp4", "background", "hero" ],
	"supports": {
		"html": false,
		"anchor": true,
		"className": true
	},
	"attributes": {
		"src":         { "type": "string",  "default": "" },
		"poster":      { "type": "string",  "default": "" },
		"mediaId":     { "type": "number",  "default": 0 },
		"posterId":    { "type": "number",  "default": 0 },
		"autoplay":    { "type": "boolean", "default": false },
		"loop":        { "type": "boolean", "default": false },
		"muted":       { "type": "boolean", "default": false },
		"playsinline": { "type": "boolean", "default": false },
		"controls":    { "type": "boolean", "default": false }
	},
	"editorScript": "ekwa-video-editor"
}
