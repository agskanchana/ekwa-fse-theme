{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/faq-container",
	"version": "1.0.0",
	"title": "Ekwa FAQ Container",
	"category": "design",
	"icon": "format-chat",
	"description": "Content-style FAQ container with separate question + answer child blocks. Emits FAQPage schema.",
	"textdomain": "ekwa",
	"keywords": [ "faq", "questions", "schema", "content" ],
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"attributes": {
		"emitSchema": { "type": "boolean", "default": true }
	},
	"editorScript": "ekwa-faq-container-editor"
}
