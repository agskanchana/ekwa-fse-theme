{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ekwa/card-link",
	"version": "1.0.0",
	"title": "Ekwa Card Link",
	"category": "design",
	"icon": "cover-image",
	"description": "A linked card wrapper — the entire card is a clickable link containing inner blocks.",
	"textdomain": "ekwa",
	"keywords": [ "card", "link", "service", "feature", "clickable" ],
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		},
		"shadow": true,
		"dimensions": {
			"minHeight": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"__experimentalLayout": true
	},
	"attributes": {
		"url":    { "type": "string",  "default": "" },
		"newTab": { "type": "boolean", "default": false },
		"rel":    { "type": "string",  "default": "" }
	},
	"editorScript": "ekwa-card-link-editor"
}
